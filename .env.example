# WW account login for JWT generation
WW_USERNAME=your_email@example.com
WW_PASSWORD=your_password

# Tenant / market
WW_TLD=de

# API settings
WW_API_BASE_URL=https://cmx.weightwatchers.de
WW_API_PROGRAM=maxpointsSimple
WW_API_TIMEOUT=20
WW_API_INSECURE=false

# Resolver behavior: if true, fallback to WW server default portionId
WW_RESOLVE_ALLOW_SERVER_DEFAULT=true

# Optional: explicitly point to env file
# WW_ENV_FILE=/Users/erikweisser/Documents/New project/.env
